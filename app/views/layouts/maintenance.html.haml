!!!
%html
  %head
    %meta{ content: 'text/html; charset=UTF-8', 'http-equiv' => 'Content-Type' }/
    %meta{ name: 'viewport', content: 'width=device-width, initial-scale=1, shrink-to-fit=no' }/
    %meta{ name: 'description', content: 'Master-Goggles maintenance page' }/
    %meta{ name: 'author', content: 'FASAR Software, Steve Alloro, 2012-2021' }/
    %meta{ name: 'keywords', content: 'Master swimming results' }/
    %title Goggles / Maintenance
    = csrf_meta_tags
    = csp_meta_tag
    = stylesheet_link_tag('https://cdn.jsdelivr.net/npm/bootstrap@4.6.2/dist/css/bootstrap.min.css',
                          media: 'all', 'data-turbo-track': 'reload')
    = stylesheet_link_tag('https://cdnjs.cloudflare.com/ajax/libs/font-awesome/4.7.0/css/font-awesome.min.css',
                          media: 'all', 'data-turbo-track': 'reload')
    = stylesheet_link_tag('https://cdn.jsdelivr.net/npm/tom-select@2.3.1/dist/css/tom-select.bootstrap4.min.css',
                          media: 'all', 'data-turbo-track': 'reload')
    = stylesheet_link_tag('https://cdn.jsdelivr.net/npm/leaflet@1.9.4/dist/leaflet.css',
                          media: 'all', 'data-turbo-track': 'reload')
    = stylesheet_link_tag('application', media: 'all', 'data-turbo-track': 'reload')
    = javascript_include_tag('https://code.jquery.com/jquery-3.7.1.min.js',
                             defer: true, 'data-turbo-track': 'reload')
    = javascript_include_tag('https://cdn.jsdelivr.net/npm/bootstrap@4.6.2/dist/js/bootstrap.bundle.min.js',
                             defer: true, 'data-turbo-track': 'reload')
    = javascript_importmap_tags

  %body
    %video.full-screen#bgvid{ autoplay: 'true', width: '100%', height: '100%', loop: 'true', muted: 'true',
      playsinline: '', poster: image_path('underwater.png') }
      %source{ src: video_path('underwater.m4v'), type: 'video/x-m4v' }

    %section#content
      .wrapper-body
        .spacer-left
        .main-content
          .maintenance= yield
        .spacer-right
