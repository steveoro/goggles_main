= form_tag(:search_smart, method: :get, class: 'form-group row-fluid',
           data: {
             turbo_frame: 'search-results',
             controller: 'loading',
             action: 'turbo:submit-start->loading#show turbo:submit-end->loading#hide'
           }) do
  .row-fluid.my-2.col-md-8.col-lg-6.offset-md-2.offset-lg-3
    .input-group.flex-fill.mt-3
      = text_field_tag(:q, nil, { class: 'form-control', 'aria-label' => I18n.t('search_view.btn_title'),
                      placeholder: I18n.t('search_view.placeholder'), type: 'search',
                      data: { toggle: 'tooltip', title: I18n.t('search_view.query_suggestion') } })
      %button.btn.btn-outline-primary{ id: 'btn-search', type: 'submit' }
        %i.fa.fa-search
