<%= turbo_stream.remove("stats-row-#{@event_type.id}") %>

<%= turbo_stream.replace("stats-hdr-#{@event_type.id}") do %>
  <%= render(
    partial: 'event_type_stats',
    locals: {
      swimmer: @swimmer,
      event_type: @event_type,
      event_total: @event_total,
      hash: @hash,
      max_updated_at: @max_updated_at
    }
  ) %>
<% end %>
