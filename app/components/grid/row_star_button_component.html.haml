- if expired?
  %i{ id: "btn-row-star-#{meeting_id}", class: "#{css_icon} #{css_highlight} disabled" }
- else
  = link_to(enabled ? taggings_by_user_path(meeting_id: meeting_id) : '#',
            { id: "btn-row-star-#{meeting_id}", data: { turbo_method: :post, turbo_stream: true } }, role: 'button',
            class: enabled ? '' : ' disabled') do
    %i{ class: "#{css_icon} #{css_highlight}" }
