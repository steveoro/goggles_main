= link_to(laps_edit_modal_path(result_id: @parent_result.id,
          result_class: @parent_result.class.name.split('::').last, show_category: @show_category,
          show_team: @show_team),
          id: "lap-req-edit-modal-#{@parent_result.id}", type: 'button',
          class: 'btn btn-sm text-success px-1 lap-edit-btn', role: 'button',
          data: { tooltip: true, turbo_method: :post, turbo_stream: true,
                  controller: 'loading',
                  action: 'click->loading#show turbo:before-fetch-response->loading#hide' },
          title: t('laps.edit_button.tooltip')) do
  %i.fa.fa-pencil-square-o
