# Ignore DB dumps uploaded in development
/db/dump/

# Generated or local runtime artifacts (must not enter production image context)
/log/
/tmp/
/coverage/
/node_modules/
/storage/
/public/assets/
/public/packs/
/db/*.sqlite3
/db/*.sqlite3-*
/db/production.sqlite3*
/db/development.sqlite3*
/db/test.sqlite3*
/vendor/bundle/
